#!/bin/bash

domain=$1

# Subdomain Enumeration
subfinder -d $domain -all -silent | tee subs.txt
amass enum -passive -d $domain -silent >> subs.txt
sort -u subs.txt -o subs.txt

# Resolve Live Hosts
cat subs.txt | httpx -silent -tech-detect -title -status-code \
  | tee live.txt

# Port Scan
cat live.txt | cut -d ' ' -f1 | naabu -silent -top-ports 1000 \
  | tee ports.txt

# Historical URLs
cat live.txt | cut -d ' ' -f1 | waybackurls \
  | tee urls.txt

# JS Files
grep "\.js$" urls.txt | sort -u > js.txt

# Extract Endpoints from JS
cat js.txt | while read url; do
    curl -s "$url"
done | grep -Eo '(https?:\/\/|\/)[A-Za-z0-9_\/\.\-\?=&]+' \
| sort -u > endpoints.txt

# Parameter Discovery
cat urls.txt | uro | gf xss > xss.txt
cat urls.txt | uro | gf sqli > sqli.txt
cat urls.txt | uro | gf ssrf > ssrf.txt
cat urls.txt | uro | gf redirect > redirect.txt

# Nuclei Scan
cat live.txt | cut -d ' ' -f1 | nuclei -severity low,medium,high,critical \
  -silent -o nuclei.txt

# Content Discovery
cat live.txt | cut -d ' ' -f1 | while read host; do
    ffuf -u "$host/FUZZ" \
         -w /usr/share/seclists/Discovery/Web-Content/common.txt \
         -mc all -fc 404 -rate 100 \
         -of csv -o ffuf.csv
done
